[Unit]
Description=VMX-pi Unix Domain Socket Controller
After=local-fs.target
ConditionPathExists=/usr/local/lib/vmxpi/libvmxpi_hal_cpp.so
StartLimitIntervalSec=30
StartLimitBurst=10

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=@INSTALL_DIR@
ExecStart=@INSTALL_DIR@/vmx_controller32
ExecStop=@INSTALL_DIR@/vmx-controller-stop.sh $MAINPID
Restart=on-failure
RestartSec=2
TimeoutStartSec=30
TimeoutStopSec=20
KillSignal=SIGTERM
KillMode=control-group
CPUAffinity=@CPU_AFFINITY@
UMask=0007
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
