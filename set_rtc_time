#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_PATH="$(readlink -f -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(
    cd -- "$(dirname -- "$SCRIPT_PATH")" &&
    pwd
)"

CLIENT="$SCRIPT_DIR/vmx_client64"

if [[ $# -ne 5 ]]; then
    echo "Usage: set_rtc_time <year> <month> <day> <hour> <minute>" >&2
    exit 2
fi

for value in "$@"; do
    [[ "$value" =~ ^[0-9]+$ ]] || {
        echo "All arguments must be integers." >&2
        exit 2
    }
done

year="$((10#$1))"
month="$((10#$2))"
day="$((10#$3))"
hour="$((10#$4))"
minute="$((10#$5))"

output="$(
    timeout 5s \
        "$CLIENT" \
        "SET_RTC_TIME $year $month $day $hour $minute" \
        GET_RTC_TIME \
        QUIT
)"

printf '%s\n' "$output"

grep -Fq \
    "OK RTC_SET YEAR=$year MONTH=$month DAY=$day HOUR=$hour MINUTE=$minute SECOND=0" \
    <<<"$output"
